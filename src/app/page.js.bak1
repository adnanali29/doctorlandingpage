481:               { title: "Psychiatrist", desc: "Mental diagnoses, emotional therapy support", fee: "₹699", icon: "bolt" },
482:               { title: "Gastroenterologist", desc: "Severe acidity, IBS, gut microbiome tracking", fee: "₹699", icon: "clipboard" },
483:               { title: "Mental Health", desc: "Daily counseling, anxiety reduction frameworks", fee: "₹799", tag: "PREMIUM", icon: "face-smile" }
484:             ].map((spec, i) => {
485:               const displayTitle = {
486:                 "General Physician": "General Physician",
487:                 "Medicine Specialist": "Internal Medicine",
488:                 "Sexologist": "Sexology",
489:                 "Gynaecologist": "Gynaecology",
490:                 "Endocrinologist": "Endocrinology",
491:                 "General Surgeon": "General Surgery",
492:                 "Psychiatrist": "Psychiatry",
493:                 "Gastroenterologist": "Gastroenterology",
494:                 "Mental Health": "Mental Health"
495:               }[spec.title] || spec.title;
496: 
497:               return (
498:                 <div
499:                   key={i}
500:                   onClick={() => openBookingModal(spec.title)}
501:                   className="flex-shrink-0 w-[280px] bg-white border border-slate-200 rounded-3xl p-6 shadow-[0_4px_24px_0_rgba(148,163,184,0.18)] hover:shadow-[0_8px_32px_0_rgba(148,163,184,0.28)] hover:border-slate-300 hover:-translate-y-1 transition-all duration-300 group snap-start cursor-pointer flex flex-col items-center text-center"
502:                 >
503:                   <div className={`w-32 h-32 rounded-full flex items-center justify-center mb-6 group-hover:scale-105 transition-transform shadow-inner ${
504:                     spec.title === "Sexologist" ? "bg-pink-50 text-pink-500" :
505:                     spec.title === "Gynaecologist" ? "bg-[#d2e3f5] text-[#2b6cb0]" :
506:                     spec.title === "Medicine Specialist" ? "bg-indigo-50 text-indigo-500" :
507:                     spec.title === "Endocrinologist" ? "bg-amber-50 text-amber-500" :
508:                     spec.title === "General Surgeon" ? "bg-purple-50 text-purple-500" :
509:                     spec.title === "Psychiatrist" ? "bg-red-50 text-red-500" :
510:                     spec.title === "Gastroenterologist" ? "bg-teal-50 text-teal-500" :
511:                     spec.title === "Mental Health" ? "bg-cyan-50 text-cyan-500" : "bg-brand-50 text-brand-500"
512:                   }`}>
513:                     {spec.icon === "shield" && <svg className="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>}
514:                     {spec.icon === "beaker" && <svg className="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>}
515:                     {spec.icon === "heart" && <svg className="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>}
516:                     {spec.icon === "user-group" && <svg className="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>}
517:                     {spec.icon === "arrow-trending-up" && <svg className="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M11.933 12.8a1 1 0 000-1.6L6.6 7.2A1 1 0 005 8v8a1 1 0 001.6.8l5.333-4zM19.933 12.8a1 1 0 000-1.6l-5.333-4A1 1 0 0013 8v8a1 1 0 001.6.8l5.333-4z"/></svg>}
518:                     {spec.icon === "scissors" && <svg className="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z"/></svg>}
519:                     {spec.icon === "bolt" && <svg className="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>}
520:                     {spec.icon === "clipboard" && <svg className="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>}
521:                     {spec.icon === "face-smile" && <svg className="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>}
522:                   </div>
523:                   
524:                   {/* Centered Title */}
525:                   <h3 className="text-[17px] font-bold text-slate-800 font-poppins mb-1 tracking-tight">
526:                     {displayTitle}
527:                   </h3>
528: 
529:                   {/* Centered Description */}
530:                   <p className="text-xs text-slate-400 font-medium mb-3 px-2 leading-relaxed">
531:                     {spec.desc}
532:                   </p>
533:                   
534:                   {/* Centered Price */}
535:                   <p className="text-slate-500 text-sm font-semibold mb-5 font-dmsans">
536:                     {spec.fee}
537:                   </p>
538: 
539:                   {/* 2 CTA Buttons */}
540:                   <div className="grid grid-cols-2 gap-2.5 w-full mt-auto">
541:                     <button
542:                       onClick={(e) => {
543:                         e.stopPropagation();
544:                         openBookingModal(spec.title);
545:                       }}
546:                       className="bg-brand-600 hover:bg-brand-700 text-white text-[11px] font-bold py-2.5 px-1 rounded-xl transition-all shadow-sm active:scale-95 text-center whitespace-nowrap"
547:                     >
548:                       Consult now
549:                     </button>
550:                     <button
551:                       onClick={(e) => {
552:                         e.stopPropagation();
553:                         openBookingModal(spec.title);
554:                       }}
555:                       className="border border-slate-200 hover:bg-slate-50 text-slate-600 text-[11px] font-bold py-2.5 px-1 rounded-xl transition-all active:scale-95 text-center whitespace-nowrap"
556:                     >
557:                       Consult later
558:                     </button>
559:                   </div>
560:                 </div>
561:               );
562:             })}
563:           </div>
564:         </div>
565:       </section>

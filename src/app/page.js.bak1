613:                     <div className="w-full h-36 bg-brand-50 rounded-2xl overflow-hidden mb-4 relative flex items-center justify-center border border-brand-100/55 group/img">
614:                       <img
615:                         src={`https://placehold.co/400x250/e0f2fe/075985?text=${encodeURIComponent(c.name)}`}
616:                         alt={c.name}
617:                         className="w-full h-full object-cover group-hover/img:scale-105 transition-transform duration-300"
618:                       />
619:                       <div className="absolute bottom-2 right-2 bg-white/95 backdrop-blur-sm text-[8px] text-slate-500 px-2 py-0.5 rounded font-mono font-bold tracking-wider border border-slate-100 shadow-sm uppercase">
620:                         Replace Asset
621:                       </div>
622:                     </div>
623: 

569:         <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
570:           <div className="flex flex-col lg:flex-row lg:items-end justify-between mb-12 gap-6">
571:             <div>
572:               <span className="text-xs font-bold text-brand-600 tracking-widest uppercase block mb-2">
573:                 Live Symptom Matching
574:               </span>
575:               <h2 className="text-3xl sm:text-4xl font-extrabold text-slate-900 font-poppins">
576:                 Identify Your Clinical Symptoms
577:               </h2>
578:               <p className="text-slate-500 mt-2 max-w-xl text-sm sm:text-base">
579:                 Search or click common issues to seamlessly trigger the correct medical specialist matching engine.
580:               </p>
581:             </div>
582: 
583:             {/* Search Input */}
584:             <div className="w-full lg:max-w-md relative">
585:               <div className="relative">
586:                 <input
587:                   type="text"
588:                   value={symptomSearchQuery}
589:                   onChange={(e) => setSymptomSearchQuery(e.target.value)}
590:                   placeholder="Type symptom (e.g., Fever, Cough, PCOS)..."
591:                   className="w-full bg-white border border-slate-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 rounded-2xl px-5 py-3.5 pl-12 text-sm focus:outline-none shadow-sm transition-all text-slate-800"
592:                 />
593:                 <svg className="w-5 h-5 text-slate-400 absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
594:                   <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
595:                 </svg>
596:               </div>
597:             </div>
598:           </div>
599: 
600:           {/* Grid Container */}
601:           {filteredConcerns.length > 0 ? (
602:             <div
603:               ref={concernsSliderRef}
604:               className="flex gap-6 overflow-x-auto scrollbar-hide scroll-smooth snap-x snap-mandatory pb-6"
605:             >
606:               {filteredConcerns.map((c, idx) => (
607:                 <div
608:                   key={idx}
